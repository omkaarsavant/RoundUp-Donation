// .env Configuration File
// Copy this to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development
BASE_URL=https://univalent-particularistically-karie.ngrok-free.dev 
# MongoDB Connection
# Local: mongodb://localhost:27017/donation-db
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/donation-db?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/donation-db

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,chrome-extension://*

# UPI Configuration (optional, for production)
UPI_PROVIDER_API_KEY=your_api_key_here
UPI_PROVIDER_SECRET=your_secret_here

